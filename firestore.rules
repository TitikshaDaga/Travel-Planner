rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net - Default Deny Catch-All
    match /{document=**} {
      allow read, write: if false;
    }

    // Common Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedEmail() {
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.providerId == 'google.com');
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Trip validator
    function isValidTrip(data) {
      return data.id is string && data.id.size() <= 128
        && data.title is string && data.title.size() <= 100 && data.title.size() > 0
        && (!('description' in data) || data.description == null || (data.description is string && data.description.size() <= 1000))
        && data.startDate is string && data.startDate.size() <= 30
        && data.endDate is string && data.endDate.size() <= 30
        && data.budget is number && data.budget >= 0
        && data.ownerId is string && data.ownerId.size() <= 128
        && data.ownerEmail is string && data.ownerEmail.size() <= 200
        && data.collaborators is list && data.collaborators.size() <= 50;
    }

    // Match Trips collection
    match /trips/{tripId} {
      allow get: if isSignedIn() && (
        existing().ownerId == request.auth.uid || 
        existing().ownerEmail == request.auth.token.email ||
        request.auth.token.email in existing().collaborators
      );

      allow list: if isSignedIn() && (
        resource.data.ownerId == request.auth.uid || 
        resource.data.ownerEmail == request.auth.token.email ||
        request.auth.token.email in resource.data.collaborators
      );

      allow create: if isSignedIn() && isValidId(tripId) && isValidTrip(incoming()) && (
        incoming().ownerId == request.auth.uid || 
        incoming().ownerEmail == request.auth.token.email
      );

      allow update: if isSignedIn() && isValidId(tripId) && isValidTrip(incoming()) && (
        // Must be current owner or collaborator to update
        existing().ownerId == request.auth.uid || 
        existing().ownerEmail == request.auth.token.email ||
        request.auth.token.email in existing().collaborators
      ) && (
        // Prevent ownership transfer except by the owner
        incoming().ownerId == existing().ownerId || 
        existing().ownerId == request.auth.uid
      );

      allow delete: if isSignedIn() && isValidId(tripId) && (
        existing().ownerId == request.auth.uid || 
        existing().ownerEmail == request.auth.token.email
      );
    }

    // UserProfile Collection Match
    match /users/{userId}/public/profile {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid;
      
      allow create, update: if isSignedIn() && userId == request.auth.uid && (
        incoming().uid == request.auth.uid &&
        incoming().email == request.auth.token.email
      );
      
      allow delete: if isSignedIn() && userId == request.auth.uid;
    }
  }
}
